# ─── Booking backend ──────────────────────────────────────────
# Required for /api/booking/* to function. Set these in Netlify env vars.

# Neon (Postgres) — pooled connection string. Free tier works.
DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# Stripe — keep test keys in dev, live keys in production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — for owner + customer email notifications.
RESEND_API_KEY=re_...
# Override the From address. Defaults to onboarding@resend.dev for testing.
# Replace with a verified domain address before going live.
FROM_EMAIL="Beautywell <hello@yourdomain.com>"

# Where booking notifications are sent.
OWNER_EMAIL=paulina@example.com

# Public site URL. Used to build success/cancel return URLs for Stripe.
SITE_URL=https://beautywell.com

# ─── Admin login (DB-backed) ──────────────────────────────────
# Used by /admin/login. Coexists with the Netlify Identity flow at /admin.

# HMAC secret for signed session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters. Keep secret; rotating it logs everyone out.
SESSION_SECRET=

# Used by `npm run seed:admin` to create or update an initial admin user.
# After the first successful seed, you can leave the password set or rotate it.
ADMIN_INITIAL_EMAIL=
ADMIN_INITIAL_PASSWORD=

# Shared secret for the daily reminder cron.
# Used by netlify/functions/send-reminders.mts to authenticate against
# /api/cron/send-reminders. Generate with `openssl rand -hex 32`.
CRON_SECRET=

# ─── Existing CMS-related env vars ────────────────────────────
# Used by /api/submit-intake to write to content/intakes.json via the GitHub API.
GITHUB_TOKEN=
